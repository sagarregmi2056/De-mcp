# --- Required for prediction calls ---
PREDICTION_API_URL=https://de.ideapreneurnepal.com.np/prediction
PREDICTION_API_TOKEN=replace_with_your_de_token

# --- Required only for live trading (DRY_RUN=false) ---
DESTINY_ENGINE_API_BASE_URL=https://your-destiny-engine.example.com
DESTINY_ENGINE_API_KEY=

# --- Optional market/pipeline controls ---
POLYMARKET_API_BASE_URL=https://gamma-api.polymarket.com
DRY_RUN=true
POLLING_SECONDS=30
MARKET_LIMIT=30
APPROVED_MARKET_KEYWORDS=
AUTO_START=false

# --- Optional Gemini enrichment ---
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_USE_SEARCH=true
